# =============================================================================
# FestManager — Biến môi trường
# Sao chép file này thành `.env` và điền giá trị thật.
# =============================================================================

# URL & anon key của Supabase project (AN TOÀN để lộ ở frontend — được bảo vệ bởi RLS)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# VAPID public key cho Web Push (an toàn để lộ — chỉ là public key)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# =============================================================================
# ✅  BẢO MẬT — service role key KHÔNG còn cần ở frontend
# -----------------------------------------------------------------------------
# Mọi thao tác admin (tạo user, đặt mật khẩu, xóa user) đã chuyển sang
# Edge Function `admin` (supabase/functions/admin/). Supabase TỰ cấp
# SUPABASE_SERVICE_ROLE_KEY cho Edge Function — bạn KHÔNG cần khai báo ở đây
# và KHÔNG được đặt nó dưới dạng VITE_* (sẽ bị nhúng vào bundle công khai).
#
# Cách deploy function: xem docs/EDGE_FUNCTION_DEPLOY.md
# =============================================================================
