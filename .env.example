# =============================================================================
# FestManager — Biến môi trường
# Sao chép file này thành `.env` và điền giá trị thật.
# =============================================================================

# URL & anon key của Supabase project (AN TOÀN để lộ ở frontend — được bảo vệ bởi RLS)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_key_here

# VAPID public key cho Web Push (an toàn để lộ — chỉ là public key)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# =============================================================================
# ⚠️  CẢNH BÁO BẢO MẬT
# -----------------------------------------------------------------------------
# KHÔNG đặt SERVICE_ROLE_KEY dưới dạng biến VITE_* (ví dụ
# VITE_SUPABASE_SERVICE_ROLE_KEY). Mọi biến VITE_* bị nhúng thẳng vào bundle
# JavaScript phía client và AI MỞ DEVTOOLS CŨNG ĐỌC ĐƯỢC. Service role key
# bỏ qua toàn bộ RLS → lộ key này tương đương trao toàn quyền database.
#
# Service role key CHỈ được dùng phía server (Supabase Edge Functions). Đặt nó
# trong secrets của Edge Function:
#   supabase secrets set SERVICE_ROLE_KEY=...
# Xem docs/DANH_GIA_VA_KE_HOACH.md · mục "Hướng dẫn triển khai Edge Functions".
# =============================================================================
